# Copia estas líneas en Portainer → Stack → Environment variables
# (o "Add an environment file" si tu versión lo permite)
# NO hace falta crear .env en el servidor.

SESSION_SECRET=cambia-por-un-secreto-largo-y-aleatorio
ADMIN_PASSWORD=tu-password-seguro
SESSION_COOKIE_SECURE=auto
TRUST_PROXY=true
PORT=3080

# Ritmo de fusiones HubSpot (valores por defecto ya optimizados)
MERGE_CONCURRENCY=3
MERGE_DELAY_MS=400
MERGE_SETTLE_MS=600
MERGE_SAME_PRIMARY_SETTLE_MS=1200
MERGE_RETRY_BASE_MS=2000
MERGE_RETRY_MAX_MS=12000
MERGE_MAX_ATTEMPTS=5
# MERGE_SKIP_PREFLIGHT=true
