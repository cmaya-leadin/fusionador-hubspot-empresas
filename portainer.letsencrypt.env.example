# Copia en Portainer → Environment variables (stack docker-compose.letsencrypt.yml)

# Dominio con DNS apuntando al VPS (obligatorio)
FUSIONADOR_DOMAIN=fusionador.tudominio.com

# Email para Let's Encrypt (avisos de caducidad; obligatorio)
LETSENCRYPT_EMAIL=tu@email.com

SESSION_SECRET=genera-un-secreto-largo-y-aleatorio
ADMIN_PASSWORD=tu-password-seguro
SESSION_COOKIE_SECURE=auto
TRUST_PROXY=true
