# Puerto del servidor web
PORT=3000

# Secreto para sesiones y cifrado de tokens HubSpot (OBLIGATORIO cambiar en producción)
SESSION_SECRET=cambia-este-secreto-en-produccion

# Contraseña inicial del usuario admin (solo se usa al crear la BD por primera vez)
ADMIN_PASSWORD=admin

# Docker / reverse proxy (Portainer, Nginx, Traefik…)
# SESSION_COOKIE_SECURE=true   # solo con HTTPS y TRUST_PROXY=true
# SESSION_COOKIE_SECURE=auto   # recomendado detrás de proxy TLS
# TRUST_PROXY=true
# HOST=0.0.0.0

# Opcional: token global de HubSpot (los proyectos usan su propio token)
# HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ritmo de fusiones en HubSpot (ms entre cada merge y tras cada éxito)
# MERGE_DELAY_MS=1000
# MERGE_SETTLE_MS=2000
# MERGE_MAX_ATTEMPTS=5